                                      ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/FilmesInfantis
:FilmesInfantis rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :temGenero ;
                                                             owl:hasValue :G_Infantil
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Filme .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/FilmesRomanticos
:FilmesRomanticos rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :temGenero ;
                                                               owl:hasValue :G_Romance
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/FilmesThriller
:FilmesThriller rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :temGenero ;
                                                             owl:hasValue :G_Thriller
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Filme .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/Género
:Género rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:oneOf ( :G_Acçao
                                          :G_Aventura
                                          :G_Comedia
