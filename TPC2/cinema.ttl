###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/F_duracao
:F_duracao rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:integer .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/F_titulo
:F_titulo rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temSexo
:temSexo rdf:type owl:DatatypeProperty ;
