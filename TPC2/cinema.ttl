#    Object Properties
#################################################################

###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/atuou
:atuou rdf:type owl:ObjectProperty ;
       owl:inverseOf :temAtor .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/compos
:compos rdf:type owl:ObjectProperty ;
        owl:inverseOf :foiComposta ;
        rdfs:domain :Pessoa ;
        rdfs:range :Obra .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/ePersonagem
:ePersonagem rdf:type owl:ObjectProperty ;
             owl:inverseOf :representa ;
             rdfs:domain :Personagem ;
             rdfs:range :Ator .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/escreveu
:escreveu rdf:type owl:ObjectProperty ;
          owl:inverseOf :foiEscrito ;
          rdfs:domain :Pessoa ;
          rdfs:range :Obra .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/foiComposta
:foiComposta rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/foiEscrito
:foiEscrito rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/foiRealizado
:foiRealizado rdf:type owl:ObjectProperty ;
              owl:inverseOf :realizou .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/realizou
:realizou rdf:type owl:ObjectProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Pessoa ;
          rdfs:range :Filme .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/representa
:representa rdf:type owl:ObjectProperty ;
            rdfs:domain :Ator ;
            rdfs:range :Personagem .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temArgumento
:temArgumento rdf:type owl:ObjectProperty ;
              rdfs:domain :Filme ;
              rdfs:range :Argumento .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temAtor
:temAtor rdf:type owl:ObjectProperty ;
         rdfs:domain :Filme ;
         rdfs:range :Pessoa .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temGenero
:temGenero rdf:type owl:ObjectProperty ;
           rdfs:domain :Filme ;
           rdfs:range :Género .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temLingua
:temLingua rdf:type owl:ObjectProperty ;
           rdfs:domain :Filme ;
           rdfs:range :Lingua .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temPaisOrigem
:temPaisOrigem rdf:type owl:ObjectProperty ;
               rdfs:domain :Filme ;
               rdfs:range :Pais .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/temPecaMusical
:temPecaMusical rdf:type owl:ObjectProperty ;
