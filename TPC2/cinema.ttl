#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/Argumento
:Argumento rdf:type owl:Class ;
           rdfs:subClassOf :Obra .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/Ator
:Ator rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :atuou ;
                                                   owl:someValuesFrom :Filme
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/AtorFeminino
:AtorFeminino rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Ator
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :temSexo ;
                                                           owl:hasValue "F"
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/AtorMasculino
:AtorMasculino rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Ator
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :temSexo ;
                                                            owl:hasValue "M"
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/Escritor
:Escritor rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :escreveu ;
                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                            owl:unionOf ( :Argumento
                                                                                          :Livro
                                                                                        )
                                                                          ]
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/Filme
:Filme rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :F_data ;
                         owl:someValuesFrom xsd:string
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :F_duracao ;
                         owl:someValuesFrom xsd:integer
                       ] .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/FilmesAventura
:FilmesAventura rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :temGenero ;
                                                             owl:hasValue :G_Aventura
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Filme .


###  http://www.semanticweb.org/joaomoura03/ontologies/2026/1/cinema/FilmesDramaticos
:FilmesDramaticos rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :temGenero ;
